                          description="Derived Column Expression"
                          name="Expression">[YEAR]((DT_DBDATE)#{Package\Data Flow Load Dim Driver\OLE DB Source Driver.Outputs[OLE DB Source Output].Columns[JoinDate]})</property>
                        <property
                          containsID="true"
                          dataType="System.String"
                          description="Derived Column Friendly Expression"
                          expressionType="Notify"
                          name="FriendlyExpression">YEAR((DT_DBDATE)JoinDate)</property>
                      </properties>
                    </outputColumn>
                    <outputColumn
                      refId="Package\Data Flow Load Dim Driver\Derived Column.Outputs[Derived Column Output].Columns[Age]"
                      dataType="i4"
                      errorOrTruncationOperation="Computation"
                      errorRowDisposition="FailComponent"
                      lineageId="Package\Data Flow Load Dim Driver\Derived Column.Outputs[Derived Column Output].Columns[Age]"
                      name="Age"
                      truncationRowDisposition="FailComponent">
                      <properties>
                        <property
                          containsID="true"
                          dataType="System.String"
                          description="Derived Column Expression"
                          name="Expression">[DATEDIFF]("yy",(DT_DBDATE)#{Package\Data Flow Load Dim Driver\OLE DB Source Driver.Outputs[OLE DB Source Output].Columns[DateOfBirth]},[GETDATE]()) - (([MONTH]((DT_DBDATE)#{Package\Data Flow Load Dim Driver\OLE DB Source Driver.Outputs[OLE DB Source Output].Columns[DateOfBirth]}) &gt; [MONTH]([GETDATE]())) || ([MONTH]((DT_DBDATE)#{Package\Data Flow Load Dim Driver\OLE DB Source Driver.Outputs[OLE DB Source Output].Columns[DateOfBirth]}) == [MONTH]([GETDATE]()) &amp;&amp; [DAY]((DT_DBDATE)#{Package\Data Flow Load Dim Driver\OLE DB Source Driver.Outputs[OLE DB Source Output].Columns[DateOfBirth]}) &gt; [DAY]([GETDATE]())) ? 1 : 0)</property>
                        <property
                          containsID="true"
                          dataType="System.String"
                          description="Derived Column Friendly Expression"
                          expressionType="Notify"
                          name="FriendlyExpression">DATEDIFF("yy",(DT_DBDATE)DateOfBirth,GETDATE()) - ((MONTH((DT_DBDATE)DateOfBirth) &gt; MONTH(GETDATE())) || (MONTH((DT_DBDATE)DateOfBirth) == MONTH(GETDATE()) &amp;&amp; DAY((DT_DBDATE)DateOfBirth) &gt; DAY(GETDATE())) ? 1 : 0)</property>
                      </properties>
                    </outputColumn>
