              componentClassID="Microsoft.OLEDBSource"
              contactInfo="OLE DB Source;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;7"
              description="OLE DB Source"
              name="OLE DB Source Trip"
              usesDispositions="true"
              version="7">
              <properties>
                <property
                  dataType="System.Int32"
                  description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                  name="CommandTimeout">0</property>
                <property
                  dataType="System.String"
                  description="Specifies the name of the database object used to open a rowset."
                  name="OpenRowset">[dbo].[Trip]</property>
                <property
                  dataType="System.String"
                  description="Specifies the variable that contains the name of the database object used to open a rowset."
                  name="OpenRowsetVariable"></property>
                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT 
    TripID, RiderID, DriverID, PickupZoneID, DropOffZoneID, 
    PaymentID, PromotionID, SeasonID, SurgeRuleID,
    Status AS TripStatus, DistanceKM, DurationMinutes, BaseFare, 
    SeasonalSurgeMultiplier, TimeSurgeMultiplier, DiscountPercentage, 
    FinalFare, CancellationReason, CancelledBy,

    -- Split RequestTime into Date and Time for the lookups
    CAST(RequestTime AS DATE) AS PureRequestDate,
    CAST(RequestTime AS TIME) AS PureRequestTime,

    -- Split the other times (they can be NULL)
    CAST(AcceptanceTime AS TIME) AS PureAcceptanceTime,
    CAST(PickupTime AS TIME) AS PurePickupTime,
    CAST(DropOffTime AS TIME) AS PureDropOffTime,

    -- Derive your flags and measures
    CAST(CASE WHEN Status = 'Cancelled' THEN 1 ELSE 0 END AS BIT) AS IsCancelled,
    DATEDIFF(MINUTE, RequestTime, AcceptanceTime) AS WaitTimeMinutes,
    DATEDIFF(MINUTE, AcceptanceTime, PickupTime) AS PickupWaitMinutes
FROM Trip;</property>
