    <DTS:Executable
      DTS:refId="Package\Delete &amp; Reset All Tables"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{3426D21F-08C0-49C8-9B72-BDEFB58B58A0}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Delete &amp; Reset All Tables"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{FB702B8E-6231-4673-92BB-5F79ABF56BA8}"
          SQLTask:SqlStatementSource="-- ============================================================&#xA;-- RIDELYTICS DWH — SAFE CLEANUP BEFORE SSIS LOAD&#xA;-- ============================================================&#xA;USE RidelyticsDWH;&#xA;GO&#xA;-- ============================================================&#xA;-- PHASE 1: Disable all FK constraints&#xA;-- ============================================================&#xA;ALTER TABLE Fact_Trip           NOCHECK CONSTRAINT ALL;&#xA;ALTER TABLE Fact_DriverEarnings NOCHECK CONSTRAINT ALL;&#xA;ALTER TABLE Fact_Complaint      NOCHECK CONSTRAINT ALL;&#xA;ALTER TABLE Fact_Rating         NOCHECK CONSTRAINT ALL;&#xA;GO&#xA;-- ============================================================&#xA;-- PHASE 2: DELETE all rows&#xA;-- NOTE: Dim_Date and Dim_Time are intentionally SKIPPED&#xA;--       Dim_Date  → DateKey is manual YYYYMMDD, populated once&#xA;--       Dim_Time  → TimeKey is manual HHMMSS,   populated once&#xA;-- ============================================================&#xA;-- Facts first&#xA;DELETE FROM Fact_Rating;&#xA;DELETE FROM Fact_Complaint;&#xA;DELETE FROM Fact_DriverEarnings;&#xA;DELETE FROM Fact_Trip;&#xA;-- Dims (Date &amp; Time deliberately excluded)&#xA;DELETE FROM Dim_SurgeRule;&#xA;DELETE FROM Dim_SeasonalPattern;&#xA;DELETE FROM Dim_Promotion;&#xA;DELETE FROM Dim_Payment;&#xA;DELETE FROM Dim_Driver;&#xA;DELETE FROM Dim_Rider;&#xA;DELETE FROM Dim_Zone;&#xA;GO&#xA;-- ============================================================&#xA;-- PHASE 3: Reseed IDENTITY columns&#xA;-- NOTE: Dim_Date skipped → DateKey is not IDENTITY (YYYYMMDD)&#xA;--       Dim_Time skipped → TimeKey is not IDENTITY (HHMMSS)&#xA;-- ============================================================&#xA;DBCC CHECKIDENT ('Fact_Trip',           RESEED, 0);&#xA;DBCC CHECKIDENT ('Fact_DriverEarnings', RESEED, 0);&#xA;DBCC CHECKIDENT ('Fact_Complaint',      RESEED, 0);&#xA;DBCC CHECKIDENT ('Fact_Rating',         RESEED, 0);&#xA;DBCC CHECKIDENT ('Dim_Zone',            RESEED, 0);&#xA;DBCC CHECKIDENT ('Dim_Rider',           RESEED, 0);&#xA;DBCC CHECKIDENT ('Dim_Driver',          RESEED, 0);&#xA;DBCC CHECKIDENT ('Dim_Payment',         RESEED, 0);&#xA;DBCC CHECKIDENT ('Dim_Promotion',       RESEED, 0);&#xA;DBCC CHECKIDENT ('Dim_SeasonalPattern', RESEED, 0);&#xA;DBCC CHECKIDENT ('Dim_SurgeRule',       RESEED, 0);&#xA;GO&#xA;-- ============================================================&#xA;-- PHASE 4: Re-enable all FK constraints&#xA;-- ============================================================&#xA;ALTER TABLE Fact_Trip           WITH CHECK CHECK CONSTRAINT ALL;&#xA;ALTER TABLE Fact_DriverEarnings WITH CHECK CHECK CONSTRAINT ALL;&#xA;ALTER TABLE Fact_Complaint      WITH CHECK CHECK CONSTRAINT ALL;&#xA;ALTER TABLE Fact_Rating         WITH CHECK CHECK CONSTRAINT ALL;&#xA;GO" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
