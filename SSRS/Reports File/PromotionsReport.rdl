  <df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DataSource3">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=ridelytics.database.windows.net;Initial Catalog=RidelyticsDWH</ConnectString>
      </ConnectionProperties>
      <rd:SecurityType>DataBase</rd:SecurityType>
      <rd:DataSourceID>e1b316ab-d4af-4fc6-be3d-44b65bd2d0ef</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource3</DataSourceName>
        <CommandText>SELECT
    p.PromoCode,
    p.Campaign,
    p.DiscountPercentage                    AS PromoDiscountPct,
    p.Status                                AS PromoStatus,

    COUNT(ft.TripID)                        AS TotalTrips,

    SUM(ft.BaseFare - ft.FinalFare)         AS TotalDiscountGiven,
    SUM(ft.FinalFare)                       AS TotalFinalFare,

    SUM(ft.FinalFare) / 
        NULLIF(SUM(ft.BaseFare - ft.FinalFare), 0) AS ROI,

    CASE WHEN ft.PromoKey IS NOT NULL 
         AND ft.PromoKey != 0 
         THEN 'Promo' 
         ELSE 'Non-Promo' 
    END                                     AS RiderType

FROM Fact_Trip ft
INNER JOIN Dim_Promotion p  ON ft.PromoKey       = p.PromoKey
LEFT JOIN  Dim_Date      dd ON ft.RequestDateKey = dd.DateKey

WHERE 
    ft.PromoKey IS NOT NULL
    AND ft.PromoKey != 0
    AND p.PromoCode IS NOT NULL

GROUP BY
    p.PromoCode,
    p.Campaign,
    p.DiscountPercentage,
    p.Status,
    CASE WHEN ft.PromoKey IS NOT NULL 
         AND ft.PromoKey != 0 
         THEN 'Promo' ELSE 'Non-Promo' END

ORDER BY TotalTrips DESC</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="PromoCode">
          <DataField>PromoCode</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Campaign">
          <DataField>Campaign</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="PromoDiscountPct">
          <DataField>PromoDiscountPct</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="PromoStatus">
          <DataField>PromoStatus</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TotalTrips">
          <DataField>TotalTrips</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="TotalFinalFare">
          <DataField>TotalFinalFare</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="TotalDiscountGiven">
          <DataField>TotalDiscountGiven</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="ROI">
          <DataField>ROI</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="RiderType">
          <DataField>RiderType</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
