# =====================================================
# Ridelytics Website (Frontend + Backend) - .gitignore
# =====================================================

# --- Dependencies ---
backend/node_modules/
frontend/node_modules/

# --- Next.js build output / caches ---
frontend/.next/
frontend/out/
frontend/.turbo/

# --- Env files (NEVER commit) ---
backend/.env
backend/.env.*
frontend/.env.local
frontend/.env.*

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Coverage / test output ---
coverage/

# --- OS / editor ---
.DS_Store
Thumbs.db
.vscode/
.idea/

# --- Misc ---
*.tgz
*.zip
